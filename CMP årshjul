const SKIPPED = [];


/* ===========================================================================
 *  CONSTANTS & STATE
 * =========================================================================== */
const MONTHS = ['Jan','Feb','Mar','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Des'];
const CX = 390, CY = 390, INNER_CIRCLE_R = 120, CENTER_R = 50;

let activeTypes      = new Set(Object.keys(TYPE_CONFIG));
let activePilars     = new Set(Object.keys(PILAR_CONFIG));
let activeLifecycles = new Set(Object.keys(LIFECYCLE_CONFIG));

const dotEls = [], tipEls = [];

/* helper: field on task for a given filter dimension */
const FIELD_MAP = { type: 'y', pilar: 'p', livs: 'l' };
const CONFIG_MAP = { type: TYPE_CONFIG, pilar: PILAR_CONFIG, livs: LIFECYCLE_CONFIG };
const SET_MAP   = () => ({ type: activeTypes, pilar: activePilars, livs: activeLifecycles });

/* ===========================================================================
 *  UTILITIES
 * =========================================================================== */
function esc(s) { const e = document.createElement('span'); e.textContent = s || ''; return e.innerHTML; }
function isVisible(t) { return activeTypes.has(t.y) && activePilars.has(t.p) && activeLifecycles.has(t.l); }

/* ===========================================================================
 *  DRAW WHEEL (Canvas)
 * =========================================================================== */
const canvas = document.getElementById('wc');
const ctx = canvas.getContext('2d');

function drawWheel() {
  ctx.clearRect(0, 0, 780, 780);
  const sorted = Object.entries(PILAR_CONFIG).sort((a, b) => b[1].ringRadius - a[1].ringRadius);
  const bounds = sorted.map(([, c]) => c.ringRadius).concat([INNER_CIRCLE_R]);

  /* ring fills */
  ctx.globalAlpha = 0.04;
  sorted.forEach(([, cfg], i) => {
    ctx.beginPath(); ctx.arc(CX, CY, cfg.ringRadius, 0, Math.PI * 2);
    ctx.fillStyle = cfg.ringColor || cfg.color; ctx.fill();
    ctx.beginPath(); ctx.arc(CX, CY, bounds[i + 1], 0, Math.PI * 2);
    ctx.fillStyle = '#0f172a'; ctx.fill();
  });
  ctx.globalAlpha = 1;

  /* ring outlines */
  bounds.forEach(r => {
    ctx.beginPath(); ctx.arc(CX, CY, r, 0, Math.PI * 2);
    ctx.strokeStyle = 'rgba(148,163,184,0.15)'; ctx.lineWidth = 1; ctx.stroke();
  });

  /* pilar labels inside rings */
  ctx.font = '600 10px Inter, sans-serif'; ctx.textAlign = 'center'; ctx.globalAlpha = 0.4;
  sorted.forEach(([, cfg], i) => {
    const innerR = bounds[i + 1];
    ctx.fillStyle = cfg.color;
    ctx.fillText(cfg.label.toUpperCase(), CX, CY - (innerR - 48));
  });
  ctx.globalAlpha = 1;

  /* month divider lines */
  const outerR = bounds[0] + 10;
  for (let i = 0; i < 12; i++) {
    const a = (i * 30 - 90) * Math.PI / 180;
    ctx.beginPath();
    ctx.moveTo(CX + Math.cos(a) * CENTER_R, CY + Math.sin(a) * CENTER_R);
    ctx.lineTo(CX + Math.cos(a) * outerR, CY + Math.sin(a) * outerR);
    ctx.strokeStyle = 'rgba(148,163,184,0.12)'; ctx.lineWidth = 1; ctx.stroke();
  }

  /* center circle */
  ctx.beginPath(); ctx.arc(CX, CY, CENTER_R, 0, Math.PI * 2);
  ctx.fillStyle = '#4f46e5'; ctx.fill();
  ctx.font = '700 16px Inter, sans-serif'; ctx.fillStyle = '#fff';
  ctx.fillText(YEAR, CX, CY + 5);
}

/* ===========================================================================
 *  BUILD DOTS & TOOLTIPS
 * =========================================================================== */
function buildDots() {
  const dc = document.getElementById('dots'), tc = document.getElementById('tips');
  dc.innerHTML = ''; tc.innerHTML = ''; dotEls.length = 0; tipEls.length = 0;

  const mpc = {}; TASKS.forEach(t => { const k = t.m + '-' + t.p; mpc[k] = (mpc[k] || 0) + 1; });
  const mpi = {};

  TASKS.forEach((t) => {
    const k = t.m + '-' + t.p; if (!mpi[k]) mpi[k] = 0;
    const ig = mpi[k]++, tg = mpc[k];
    const pilarCfg = PILAR_CONFIG[t.p], typeCfg = TYPE_CONFIG[t.y];
    if (!pilarCfg || !typeCfg) { dotEls.push(null); tipEls.push(null); return; }

    const br = pilarCfg.radius;
    const ms = (t.m - 1) * 30 - 90, sp = 26 / (tg + 1);
    const da = (ms + 2 + sp * (ig + 1)) * Math.PI / 180;
    const r = br + (ig % 3 - 1) * 18;
    const px = CX + Math.cos(da) * r - 5, py = CY + Math.sin(da) * r - 5;

    const d = document.createElement('div'); d.className = 'task-dot';
    d.style.cssText = `left:${px}px;top:${py}px;width:10px;height:10px;background:${typeCfg.color};box-shadow:0 0 8px ${typeCfg.color}66;`;

    const lcCfg = LIFECYCLE_CONFIG[t.l];
    const tp = document.createElement('div'); tp.className = 'hover-card';
    tp.innerHTML = `<strong>${esc(t.t)}</strong><br>${esc(typeCfg.label)} | ${esc(pilarCfg.label)}<br>${esc(lcCfg?.label || t.l)} | ${esc(t.k)} | ${esc(t.c)}`;
    tp.style.cssText = `left:${px + 16}px;top:${py - 10}px;`;

    d.addEventListener('mouseenter', () => { if (!d.classList.contains('dimmed')) tp.classList.add('show'); });
    d.addEventListener('mouseleave', () => tp.classList.remove('show'));
    dc.appendChild(d); tc.appendChild(tp); dotEls.push(d); tipEls.push(tp);
  });
}

/* ===========================================================================
 *  HIT AREAS & MONTH LINKS
 * =========================================================================== */
function buildHitAreas() {
  const ha = document.getElementById('hitAreas'); ha.innerHTML = '';
  for (let i = 0; i < 12; i++) {
    const amid = ((i * 30 + 15) - 90) * Math.PI / 180;
    const hx = CX + Math.cos(amid) * 210 - 40, hy = CY + Math.sin(amid) * 210 - 40;
    const d = document.createElement('div'); d.className = 'month-hit';
    d.style.cssText = `left:${hx}px;top:${hy}px;width:80px;height:80px;border-radius:50%;`;
    d.addEventListener('click', () => openZoom(i + 1));
    ha.appendChild(d);
  }
}

function buildMonthLinks() {
  const ml = document.getElementById('monthLinks'); ml.innerHTML = '';
  for (let i = 0; i < 12; i++) {
    const angle = ((i * 30) + 15 - 90) * Math.PI / 180;
    const lx = CX + Math.cos(angle) * 375, ly = CY + Math.sin(angle) * 375;
    const mc = TASKS.filter(t => t.m === i + 1 && isVisible(t)).length;
    const a = document.createElement('a'); a.className = 'month-label-link'; a.href = '#';
    a.addEventListener('click', e => { e.preventDefault(); openZoom(i + 1); });
    a.style.cssText = `left:${lx}px;top:${ly}px;transform:translate(-50%,-50%);display:flex;flex-direction:column;align-items:center;gap:1px;`;
    a.innerHTML = `<span class="ml-text" style="font-weight:700;font-size:12px;color:var(--color-muted);transition:color .2s;">${MONTHS[i].toUpperCase()}</span>
      <span class="ml-count" style="font-size:9px;color:var(--color-muted-dim);opacity:.6;transition:opacity .2s;">${mc || ''}</span>`;
    a.id = `ml${i + 1}`;
    ml.appendChild(a);
  }
}

/* ===========================================================================
 *  FILTER UI BUILDER
 * =========================================================================== */
function buildFilters() {
  const tb = document.getElementById('filterToolbar'); tb.innerHTML = '';
