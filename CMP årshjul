  dims.forEach(dim => {
    const g = document.createElement('div'); g.className = 'filter-group';
    g.innerHTML = `<p class="filter-group-label">${dim.label}</p>`;
    const bd = document.createElement('div'); bd.className = 'filter-group-buttons';

    /* "All" button */
    const allB = document.createElement('button'); allB.className = 'fb active';
    allB.dataset.f = dim.key; allB.dataset.v = 'all';
    allB.style.cssText = 'background:#1e293b;color:#94a3b8;';
    allB.onclick = function () { toggleFilter(this); };
    allB.innerHTML = `Alle<span class="cnt" data-count-key="${dim.key}_all" style="background:#334155;color:#cbd5e1">${TASKS.length}</span>`;
    bd.appendChild(allB);

    /* Individual buttons */
    const field = FIELD_MAP[dim.key];
    Object.entries(dim.config).forEach(([k, cfg]) => {
      const b = document.createElement('button'); b.className = 'fb active';
      b.dataset.f = dim.key; b.dataset.v = k;
      b.style.cssText = `background:${cfg.filterBg};color:${cfg.color};`;
      b.onclick = function () { toggleFilter(this); };
      const cnt = TASKS.filter(t => t[field] === k).length;
      b.innerHTML = `${esc(cfg.label || k)}<span class="cnt" data-count-key="${dim.key}_${k}" style="background:${cfg.cntBg};color:${cfg.cntColor}">${cnt}</span>`;
      bd.appendChild(b);
    });
    g.appendChild(bd); gd.appendChild(g);
  });
  tb.appendChild(gd);

  const sm = document.createElement('div'); sm.className = 'filter-summary';
  sm.innerHTML = `<p>Viser <span class="count" id="vis">${TASKS.length}</span> av ${TASKS.length}</p>
    <button onclick="resetFilters()">Nullstill</button>`;
  tb.appendChild(sm);
}

/* ===========================================================================
 *  LEGEND BUILDER
 * =========================================================================== */
function buildLegend() {
  const el = document.getElementById('legendSection');
  if (!TYPE_CONFIG || !Object.keys(TYPE_CONFIG).length) {
    el.innerHTML = '<span class="legend-item">Ingen kategorier å vise</span>'; return;
  }
  el.innerHTML = '';
  Object.values(TYPE_CONFIG).forEach(cfg => {
    const it = document.createElement('span'); it.className = 'legend-item';
    it.innerHTML = `<span class="legend-swatch" style="background:${cfg.color}"></span>${esc(cfg.label)}`;
    el.appendChild(it);
  });
  Object.values(PILAR_CONFIG).forEach(cfg => {
    const it = document.createElement('span'); it.className = 'legend-item';
    it.innerHTML = `<span class="legend-swatch" style="background:${cfg.color};border-radius:50%"></span>${esc(cfg.label)}`;
    el.appendChild(it);
  });
}

/* ===========================================================================
 *  SKIPPED TABLE BUILDER
 * =========================================================================== */
function buildSkipped() {
  const tb = document.getElementById('skippedBody');
  if (!SKIPPED || !SKIPPED.length) {
    tb.innerHTML = '<tr class="empty-row"><td colspan="2">Alle elementer er plassert i hjulet</td></tr>'; return;
  }
  tb.innerHTML = '';
  SKIPPED.forEach(s => {
    const tr = document.createElement('tr');
    tr.innerHTML = `<td>${esc(s.title)}</td><td>${esc(s.reason)}</td>`;
    tb.appendChild(tr);
  });
}

/* ===========================================================================
 *  FILTER LOGIC
 * =========================================================================== */
function applyFilters() {
  let vc = 0;
  TASKS.forEach((t, i) => {
    const v = isVisible(t); if (v) vc++;
    if (dotEls[i]) { dotEls[i].classList.toggle('dimmed', !v); tipEls[i]?.classList.remove('show'); }
  });
  const visEl = document.getElementById('vis');
  if (visEl) visEl.textContent = vc;
  document.getElementById('totalPlaced').textContent = vc;
  updateFilterCounts(vc);
  for (let i = 0; i < 12; i++) {
    const mc = TASKS.filter(t => t.m === i + 1 && isVisible(t)).length;
    const el = document.getElementById(`ml${i + 1}`);
    if (el) { const cs = el.querySelector('.ml-count'); if (cs) cs.textContent = mc || ''; }
  }
}

function updateFilterCounts(total) {
  const counts = {};
  TASKS.forEach(t => {
    if (!isVisible(t)) return;
    Object.entries(FIELD_MAP).forEach(([dim, field]) => { counts[`${dim}_${t[field]}`] = (counts[`${dim}_${t[field]}`] || 0) + 1; });
  });
  document.querySelectorAll('.cnt[data-count-key]').forEach(el => {
    const k = el.dataset.countKey;
    el.textContent = k.endsWith('_all') ? total : (counts[k] || 0);
  });
}

function toggleFilter(btn) {
  const fg = btn.dataset.f, v = btn.dataset.v;
  const sets = SET_MAP();
  const set = sets[fg], config = CONFIG_MAP[fg], allKeys = Object.keys(config);

  if (v === 'all') {
    if (allKeys.every(x => set.has(x))) { set.clear(); document.querySelectorAll(`[data-f="${fg}"]`).forEach(b => b.classList.remove('active')); }
    else { allKeys.forEach(x => set.add(x)); document.querySelectorAll(`[data-f="${fg}"]`).forEach(b => b.classList.add('active')); }
  } else {
    if (set.has(v)) { set.delete(v); btn.classList.remove('active'); }
    else { set.add(v); btn.classList.add('active'); }
    const ab = document.querySelector(`[data-f="${fg}"][data-v="all"]`);
    if (allKeys.every(x => set.has(x))) ab?.classList.add('active'); else ab?.classList.remove('active');
  }
  applyFilters();
}

function resetFilters() {
  activeTypes      = new Set(Object.keys(TYPE_CONFIG));
  activePilars     = new Set(Object.keys(PILAR_CONFIG));
  activeLifecycles = new Set(Object.keys(LIFECYCLE_CONFIG));
  document.querySelectorAll('.fb').forEach(b => b.classList.add('active'));
  applyFilters();
}

/* ===========================================================================
 *  ZOOM
 * =========================================================================== */
function openZoom(month) {
  const items = TASKS.filter(t => t.m === month && isVisible(t));
  if (!items.length) return;

  const ov = document.getElementById('zoomOverlay');
  document.getElementById('zoomTitle').textContent = MONTHS[month - 1] + ' ' + YEAR;
  document.getElementById('zoomSub').textContent = items.length + ' aktivitet' + (items.length > 1 ? 'er' : '');
  const zC = document.getElementById('zoomCanvas');
  const dotsC = document.getElementById('zoomDots'), popC = document.getElementById('zoomPopups');
  const svg = document.getElementById('zoomSvg');
  dotsC.innerHTML = ''; popC.innerHTML = ''; svg.innerHTML = '';
  ov.style.display = 'flex';
  requestAnimationFrame(() => ov.classList.add('show'));

  requestAnimationFrame(() => {
    const rect = zC.getBoundingClientRect(), W = rect.width, H = rect.height;
    const ccx = W / 2, ccy = H / 2, maxR = Math.min(W, H) / 2 - 20;
    svg.setAttribute('viewBox', `0 0 ${W} ${H}`);

    const a1 = ((month - 1) * 30 - 90) * Math.PI / 180, a2 = (month * 30 - 90) * Math.PI / 180;

    /* slice */
    const sp = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    const r1 = maxR * 0.12, r2 = maxR * 0.95;
    sp.setAttribute('d', `M${ccx+Math.cos(a1)*r1},${ccy+Math.sin(a1)*r1} L${ccx+Math.cos(a1)*r2},${ccy+Math.sin(a1)*r2} A${r2},${r2} 0 0,1 ${ccx+Math.cos(a2)*r2},${ccy+Math.sin(a2)*r2} L${ccx+Math.cos(a2)*r1},${ccy+Math.sin(a2)*r1} A${r1},${r1} 0 0,0 ${ccx+Math.cos(a1)*r1},${ccy+Math.sin(a1)*r1}`);
    sp.setAttribute('fill', 'rgba(99,102,241,0.06)'); sp.setAttribute('stroke', 'rgba(99,102,241,0.2)'); sp.setAttribute('stroke-width', '1.5');
    svg.appendChild(sp);

    [0.3, 0.55, 0.75].forEach(f => {
      const rr = maxR * f, arc = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      arc.setAttribute('d', `M${ccx+Math.cos(a1)*rr},${ccy+Math.sin(a1)*rr} A${rr},${rr} 0 0,1 ${ccx+Math.cos(a2)*rr},${ccy+Math.sin(a2)*rr}`);
      arc.setAttribute('fill', 'none'); arc.setAttribute('stroke', 'rgba(148,163,184,0.1)'); arc.setAttribute('stroke-width', '1');
      svg.appendChild(arc);
    });

    /* pilar labels & ratios */
    const pilarEntries = Object.entries(PILAR_CONFIG);
    const ratios = [0.82, 0.58, 0.35];
    const pilarR = {}; pilarEntries.forEach(([k], i) => { pilarR[k] = ratios[i] || 0.5; });
    const amid = (a1 + a2) / 2;
    pilarEntries.forEach(([k, cfg], i) => {
      const pr = maxR * pilarR[k], txt = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      txt.setAttribute('x', ccx + Math.cos(amid) * pr); txt.setAttribute('y', ccy + Math.sin(amid) * pr - 18);
      txt.setAttribute('text-anchor', 'middle'); txt.setAttribute('fill', cfg.color);
      txt.setAttribute('font-size', '10'); txt.setAttribute('font-weight', '600'); txt.setAttribute('opacity', '0.4');
      txt.textContent = cfg.label.toUpperCase(); svg.appendChild(txt);
    });

    /* dots */
    const dotPos = [], byPilar = {};
    items.forEach((t, i) => { if (!byPilar[t.p]) byPilar[t.p] = []; byPilar[t.p].push({ task: t, idx: i }); });

    Object.keys(byPilar).forEach(p => {
      const grp = byPilar[p], baseR = maxR * (pilarR[p] || 0.5);
      const aStart = (month - 1) * 30 - 90 + 1, spacing = 28 / (grp.length + 1);
      grp.forEach((item, gi) => {
        const ang = (aStart + spacing * (gi + 1)) * Math.PI / 180;
        const r = baseR + (gi % 2 === 0 ? -12 : 12);
        const dx = ccx + Math.cos(ang) * r, dy = ccy + Math.sin(ang) * r;
        dotPos.push({ x: dx, y: dy, task: item.task });
        const tc = TYPE_CONFIG[item.task.y], dot = document.createElement('div');
        dot.className = 'zoom-dot';
        dot.style.cssText = `left:${dx-7}px;top:${dy-7}px;width:14px;height:14px;background:${tc.color};box-shadow:0 0 16px ${tc.color}88;`;
        dotsC.appendChild(dot);
      });
    });

    /* popups with collision avoidance */
    const popW = 220, popH = 58, used = [];
    function overlaps(rx, ry, rw, rh) { for (const u of used) { if (!(rx+rw<u.x||rx>u.x+u.w||ry+rh<u.y||ry>u.y+u.h)) return true; } return false; }

    dotPos.forEach(dp => {
      const offsets = [{ox:30,oy:-popH/2},{ox:-popW-30,oy:-popH/2},{ox:-popW/2,oy:-popH-25},{ox:-popW/2,oy:25},{ox:50,oy:-popH-10},{ox:50,oy:20},{ox:-popW-50,oy:-popH-10},{ox:-popW-50,oy:20},{ox:80,oy:-popH/2},{ox:-popW-80,oy:-popH/2},{ox:30,oy:-popH-40},{ox:30,oy:40},{ox:-popW/2,oy:-popH-50},{ox:-popW/2,oy:55},{ox:100,oy:-10},{ox:-popW-100,oy:-10}];
      let px = dp.x + 30, py = dp.y - popH / 2;
      for (const o of offsets) {
        const tx = dp.x + o.ox, ty = dp.y + o.oy;
        if (tx > 5 && tx + popW < W - 5 && ty > 5 && ty + popH < H - 5 && !overlaps(tx, ty, popW, popH)) { px = tx; py = ty; break; }
      }
      used.push({ x: px, y: py, w: popW, h: popH });

      const t = dp.task, tc = TYPE_CONFIG[t.y], pc = PILAR_CONFIG[t.p], lc = LIFECYCLE_CONFIG[t.l];
      const pop = document.createElement('div'); pop.className = 'zoom-popup';
      pop.style.cssText = `left:${px}px;top:${py}px;width:${popW}px;background:${tc.bg};border-color:${tc.border};`;
      pop.innerHTML = `<div style="color:${tc.color};font-weight:700;font-size:13px;margin-bottom:2px;">${esc(t.t)}</div>
        <div style="color:rgba(226,232,240,0.7);font-size:11px;">${esc(pc.label)} <span class="badge-sm" style="background:${tc.border};color:${tc.color}">${esc(lc?.label||t.l)}</span> <span style="color:rgba(148,163,184,0.6)">via ${esc(t.k)}</span></div>`;
      popC.appendChild(pop);

      const pcx = px + (dp.x < px ? 0 : popW), pcy = py + popH / 2;
      if (Math.sqrt((pcx-dp.x)**2 + (pcy-dp.y)**2) > 35) {
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', dp.x); line.setAttribute('y1', dp.y);
        line.setAttribute('x2', pcx); line.setAttribute('y2', pcy);
        line.setAttribute('stroke', tc.color); line.setAttribute('stroke-width', '1');
        line.setAttribute('stroke-opacity', '0.3'); line.setAttribute('stroke-dasharray', '4,3');
        svg.appendChild(line);
      }
    });
  });
}

function closeZoom() {
  const ov = document.getElementById('zoomOverlay');
  ov.classList.remove('show');
  setTimeout(() => { ov.style.display = 'none'; }, 400);
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeZoom(); });

/* ===========================================================================
 *  INIT
 * =========================================================================== */
function init() {
  document.getElementById('yearDisplay').textContent = YEAR;
  document.getElementById('viewName').textContent = SAVED_VIEW_NAME;
  document.getElementById('footerTimestamp').textContent = TIMESTAMP;
  document.getElementById('totalItems').textContent = TASKS.length;

  drawWheel();
  buildDots();
  buildHitAreas();
  buildMonthLinks();
  buildFilters();
  buildLegend();
  buildSkipped();
  applyFilters();
}
init();
